# Copy this to .env.local and fill in real values. Never commit .env.local —
# it now IS gitignored (it wasn't before this cleanup — see the reorg notes
# in docs/update-notes/ if you're wondering why that matters).

HOSTINGER_UPLOAD_URL=https://uploads.example.com/upload.php
UPLOAD_SECRET=change_me

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Admin panel password — use a real, unique, generated password, not a
# dictionary word / product name. This gates every /admin route.
ADMIN_PASSWORD=change_me
